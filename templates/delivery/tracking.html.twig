{% extends 'base.html.twig' %}

{% block title %}Track Your Delivery{% endblock %}

{% block body %}
{# ── Leaflet CSS ── MUST be first ─────────────────────────────────────── #}
<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />

<div class="admin-container">
    <div class="admin-header">
        <h1>Track Your Delivery</h1>
        <p>Order #{{ delivery.order_id }}</p>
    </div>

    <div class="tracking-container">

        {# ══ LEFT COLUMN ══════════════════════════════════════════════════ #}
        <div class="tracking-left">
            <div class="tracking-info">

                <div class="info-card">
                    <h3>Delivery Details</h3>
                    <table class="admin-table">
                        <tbody>
                            <tr><td><strong>Order Number:</strong></td><td>{{ delivery.order_id }}</td></tr>
                            <tr>
                                <td><strong>Status:</strong></td>
                                <td><span class="status-badge status-{{ delivery.status|lower }}">{{ delivery.status }}</span></td>
                            </tr>
                            <tr><td><strong>Estimated Time:</strong></td><td>{{ delivery.estimated_time }} minutes</td></tr>
                            <tr><td><strong>Delivery Address:</strong></td><td>{{ delivery.delivery_address }}</td></tr>
                            <tr><td><strong>Recipient:</strong></td><td>{{ delivery.recipient_name }}</td></tr>
                        </tbody>
                    </table>
                </div>

                {% if delivery.deliveryMan %}
                <div class="info-card">
                    <h3>Your Delivery Person</h3>
                    <table class="admin-table">
                        <tbody>
                            <tr><td><strong>Name:</strong></td><td>{{ delivery.deliveryMan.name }}</td></tr>
                            <tr><td><strong>Phone:</strong></td><td>{{ delivery.deliveryMan.phone }}</td></tr>
                            <tr><td><strong>Vehicle:</strong></td><td>{{ delivery.deliveryMan.vehicle_type }}</td></tr>
                            {% if delivery.deliveryMan.rating %}
                            <tr><td><strong>Rating:</strong></td><td>{{ delivery.deliveryMan.rating }}/5 ⭐</td></tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
                {% endif %}

                {% if delivery.cart_items %}
                <div class="info-card">
                    <h3>Ordered Items</h3>
                    <div class="order-items">
                        {% set items = delivery.cart_items ? delivery.cart_items|split('\n') : [] %}
                        <ul style="list-style:none;padding:0;margin:0;">
                            {% for it in items %}
                                {% if it is not empty %}
                                <li style="padding:.45rem 0;border-bottom:1px dashed rgba(44,26,14,.04);display:flex;justify-content:space-between;align-items:center;">
                                    <span style="font-weight:600;color:var(--espresso)">{{ it }}</span>
                                </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </div>
                    <p class="order-total"><strong>Total:</strong> {{ delivery.order_total }} TND</p>
                </div>
                {% endif %}

            </div>{# /tracking-info #}
        </div>{# /tracking-left #}

        {# ══ RIGHT COLUMN ═════════════════════════════════════════════════ #}
        <div class="tracking-right">

            {# ── Timeline ── #}
            <div class="tracking-timeline">
                <h3>Delivery Progress</h3>
                <div class="timeline">

                    <div class="timeline-item {% if delivery.status in ['PENDING','ASSIGNED','PICKED_UP','IN_TRANSIT','DELIVERED'] %}active{% endif %}">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>Order Placed</h4>
                            <p>Your order has been received and is being processed.</p>
                            {% if delivery.created_at %}<small>{{ delivery.created_at|date('M j, Y g:i A') }}</small>{% endif %}
                        </div>
                    </div>

                    <div class="timeline-item {% if delivery.status in ['ASSIGNED','PICKED_UP','IN_TRANSIT','DELIVERED'] %}active{% endif %}">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>Delivery Assigned</h4>
                            <p>A delivery person has been assigned to your order.</p>
                            {% if delivery.deliveryMan %}<p><strong>{{ delivery.deliveryMan.name }}</strong> will deliver your order.</p>{% endif %}
                        </div>
                    </div>

                    <div class="timeline-item {% if delivery.status in ['PICKED_UP','IN_TRANSIT','DELIVERED'] %}active{% endif %}">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>Order Picked Up</h4>
                            <p>Your order has been picked up and is on the way.</p>
                        </div>
                    </div>

                    <div class="timeline-item {% if delivery.status in ['IN_TRANSIT','DELIVERED'] %}active{% endif %}">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>Out for Delivery</h4>
                            <p>Your order is currently being delivered.</p>
                        </div>
                    </div>

                    <div class="timeline-item {% if delivery.status == 'DELIVERED' %}active{% endif %}">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>Delivered</h4>
                            <p>Your order has been successfully delivered.</p>
                            {% if delivery.actual_delivery_date %}<small>{{ delivery.actual_delivery_date|date('M j, Y g:i A') }}</small>{% endif %}
                        </div>
                    </div>

                </div>{# /timeline #}
            </div>{# /tracking-timeline #}

            {# ── Live Map card ── #}
            <div class="map-card info-card">
                <h3>Live Map</h3>

                {% if delivery.status in ['DELIVERED', 'CANCELLED'] %}
                    {# Terminal — static message, no JS needed #}
                    <div id="deliveryMap" class="map-shell map-done">
                        {% if delivery.status == 'DELIVERED' %}
                            <div><strong style="color:#2E9E6A">✅ Order Delivered!</strong><div style="margin-top:.4rem;color:var(--text-3)">Live tracking has ended.</div></div>
                        {% else %}
                            <div><strong style="color:#e74c3c">❌ Order Cancelled</strong><div style="margin-top:.4rem;color:var(--text-3)">Live tracking has ended.</div></div>
                        {% endif %}
                    </div>
                {% else %}
                    {#
                        data-location-url  → GET polls here; POST from driver goes here
                        data-client-lat/lon → saved when client placed the order
                        data-driver-lat/lon → last known driver position (may be empty initially)
                    #}
                    <div
                        id="deliveryMap"
                        class="map-shell"
                        data-delivery-id="{{ delivery.delivery_id }}"
                        data-client-lat="{{ delivery.currentLatitude|default('') }}"
                        data-client-lon="{{ delivery.currentLongitude|default('') }}"
                        data-driver-lat="{{ delivery.driverLatitude|default('') }}"
                        data-driver-lon="{{ delivery.driverLongitude|default('') }}"
                        data-location-url="{{ path('app_delivery_update_location', {'id': delivery.delivery_id}) }}"
                    >
                        <div>
                            <strong>Map loading…</strong>
                            <div style="margin-top:.35rem;color:var(--text-3);font-size:.9rem;">Waiting for driver location…</div>
                        </div>
                    </div>
                {% endif %}

                <p style="margin-top:.6rem;text-align:center;">
                    <a id="deliveryMapLink" href="#" target="_blank" class="btn btn-secondary"
                       style="pointer-events:none;opacity:.6;">Open in Maps</a>
                </p>
                <div style="display:flex;gap:.5rem;align-items:center;justify-content:center;margin-top:.45rem;flex-direction:column;">
                    <div id="distanceLabel" class="distance-label" style="display:none;">Distance: --</div>
                    <div id="etaLabel"      class="eta-label"      style="display:none;">ETA: --</div>
                    <div id="statusLabel"   class="status-label"   style="display:none;">--</div>
                </div>
            </div>{# /map-card #}

        </div>{# /tracking-right #}

        {# ── Rating section (DELIVERED only) ── #}
        {% if delivery.status == 'DELIVERED' %}
        <div class="rating-section">
            <h3>Rate Your Delivery Experience</h3>
            {% for label in ['success', 'error'] %}
                {% for msg in app.flashes(label) %}
                    <div class="alert alert-{{ label }}">{{ msg }}</div>
                {% endfor %}
            {% endfor %}

            <form method="post" class="rating-form">
                <div class="rating-block">
                    <h4>Rate your delivery man</h4>
                    <div class="rating-stars" role="group" aria-label="Delivery man rating">
                        {% for value in 5..1 %}
                        <input type="radio" id="dm-star{{ value }}" name="delivery_man_rating" value="{{ value }}" {% if delivery.rating == value %}checked{% endif %}>
                        <label for="dm-star{{ value }}">★</label>
                        {% endfor %}
                    </div>
                    {% if delivery.rating %}<p class="current-rating">Your rating: <strong>{{ delivery.rating }}/5</strong></p>{% endif %}
                </div>

                <div class="rating-block">
                    <h4>Rate the restaurant &amp; order</h4>
                    <div class="rating-stars" role="group" aria-label="Restaurant rating">
                        {% for value in 5..1 %}
                        <input type="radio" id="rest-star{{ value }}" name="restaurant_rating" value="{{ value }}" {% if delivery.restaurant_rating == value %}checked{% endif %}>
                        <label for="rest-star{{ value }}">★</label>
                        {% endfor %}
                    </div>
                    {% if delivery.restaurant_rating %}<p class="current-rating">Your rating: <strong>{{ delivery.restaurant_rating }}/5</strong></p>{% endif %}
                </div>

                <div class="rating-block" style="margin-top:1.5rem;">
                    <h4>Share a short review</h4>
                    <textarea name="review_text" rows="4" placeholder="Tell us what you loved or what could be better"
                              style="width:100%;padding:.85rem 1rem;border-radius:14px;border:1px solid rgba(184,135,42,.18);font-family:'Jost',sans-serif;resize:vertical;"></textarea>
                    <input type="email" name="review_email" placeholder="Email (optional)"
                           style="width:100%;margin-top:.7rem;padding:.75rem 1rem;border-radius:14px;border:1px solid rgba(184,135,42,.18);font-family:'Jost',sans-serif;">
                    <p style="margin-top:.6rem;color:var(--text-3);font-size:.9rem;">Positive reviews may appear on our homepage with an AI-verified badge.</p>
                </div>

                <button type="submit" class="btn btn-primary">Submit Ratings</button>
            </form>
        </div>
        {% endif %}

    </div>{# /tracking-container #}

    <div class="admin-actions">
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Back to Home</a>
    </div>
</div>

{# ══ STYLES ════════════════════════════════════════════════════════════════ #}
<style>
.tracking-container{display:grid;grid-template-columns:1fr 420px;gap:2rem;margin-top:2rem;}
.tracking-left{display:block}
.tracking-right{display:flex;flex-direction:column;gap:1rem}
.tracking-info{display:block;gap:1rem}
.info-card{background:var(--ivory);border:1px solid rgba(184,135,42,.12);border-radius:12px;padding:1.25rem;box-shadow:0 6px 18px rgba(44,26,14,0.04);}
.info-card h3{color:var(--gold);margin-bottom:.75rem;font-size:1.05rem;letter-spacing:.02em;}
.status-badge{display:inline-block;padding:.35rem .6rem;border-radius:999px;font-weight:700;font-size:.85rem;letter-spacing:.06em;color:#fff;background:rgba(44,26,14,.08);}
.status-pending{background:#F4C95A;color:#5a3b00}
.status-assigned{background:#6CC2A2;color:#043522}
.status-picked_up{background:#e6c273;color:#4a2a00}
.status-in_transit{background:#d9a441;color:#3a2200}
.status-delivered{background:#2E9E6A;color:#fff}
.map-card.info-card{padding:1.4rem;}
.map-shell{width:100%;height:280px;border-radius:16px;background:radial-gradient(circle at 30% 20%,rgba(184,135,42,.18),transparent 45%),linear-gradient(180deg,#fbf6ec 0%,#f6efe1 100%);border:1px dashed rgba(184,135,42,.25);display:flex;align-items:center;justify-content:center;color:var(--text-3);text-align:center;padding:1.2rem;}
.map-shell strong{color:var(--brown);display:block;margin-bottom:.35rem;}
.map-done{border-style:solid;border-color:rgba(184,135,42,.18);}
.tracking-timeline{grid-column:1 / -1;}
.timeline{position:relative;padding-left:2.6rem;}
.timeline::before{content:'';position:absolute;left:1.6rem;top:0;bottom:0;width:3px;background:linear-gradient(180deg,rgba(184,135,42,0.9),rgba(184,135,42,0.6));border-radius:2px;}
.timeline-item{position:relative;margin-bottom:1.6rem;opacity:0.45;transition:opacity .25s ease,transform .25s ease;}
.timeline-item.active{opacity:1;transform:translateY(-2px);}
.timeline-marker{position:absolute;left:-1.2rem;top:0.25rem;width:1.2rem;height:1.2rem;border-radius:50%;background:#fff;border:4px solid rgba(184,135,42,0.95);box-shadow:0 4px 10px rgba(44,26,14,0.06);}
.timeline-item.active .timeline-marker::after{content:'';position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:26px;height:26px;border-radius:50%;border:2px solid rgba(184,135,42,.18);animation:pulse 1.6s infinite;}
@keyframes pulse{0%{transform:translate(-50%,-50%) scale(.7);opacity:.9}70%{transform:translate(-50%,-50%) scale(1.3);opacity:0}100%{opacity:0}}
.timeline-content h4{margin:0 0 .35rem 0;color:var(--gold);font-size:1.05rem;}
.timeline-content p{margin:0 0 .4rem 0;color:var(--text-2);font-size:.975rem;}
.timeline-content small{color:var(--text-3);font-size:0.875rem;}
.rating-section{grid-column:1 / -1;background:var(--ivory);border:1px solid rgba(184,135,42,.12);border-radius:10px;padding:1.25rem;text-align:center;}
.rating-form{margin-top:1rem;}
.rating-stars{display:flex;justify-content:center;gap:.5rem;margin-bottom:1rem;}
.rating-stars input[type="radio"]{display:none;}
.rating-stars label{font-size:1.9rem;cursor:pointer;transition:color .18s ease;color:var(--text-3);margin:0 .12rem;}
.rating-stars input[type="radio"]:checked + label,.rating-stars input[type="radio"]:checked + label ~ label,.rating-stars label:hover,.rating-stars label:hover ~ label{color:var(--gold);}
.rating-block{margin-bottom:1.75rem;}
.rating-block h4{margin-bottom:1rem;color:var(--espresso);font-size:1rem;}
.current-rating{margin-top:.75rem;color:var(--text-2);}
.alert{padding:1rem;border-radius:4px;margin-bottom:1rem;}
.alert-success{background:#d4edda;color:#155724;border:1px solid #c3e6cb;}
.alert-error{background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;}
.btn{display:inline-block;padding:.6rem 1.1rem;border:none;border-radius:8px;text-decoration:none;font-weight:700;text-align:center;cursor:pointer;transition:all .18s ease;font-size:.95rem;}
.btn-primary{background:linear-gradient(180deg,var(--gold),var(--gold-2));color:var(--espresso);}
.btn-primary:hover{filter:brightness(.92);}
.btn-secondary{background:rgba(184,135,42,.08);color:var(--brown);border:1px solid rgba(184,135,42,.24);}
.admin-actions{margin-top:1.5rem;display:flex;justify-content:flex-start;}
.driver-marker,.client-marker{position:relative;}
.driver-label{background:#ff8f2b;color:#fff;padding:.25rem .6rem;border-radius:10px;font-weight:700;font-size:.7rem;letter-spacing:.04em;box-shadow:0 6px 16px rgba(0,0,0,.18);transform:translateY(-6px);text-transform:uppercase;white-space:nowrap;}
.driver-dot{width:14px;height:14px;background:#ff8f2b;border:3px solid #fff;border-radius:50%;margin:.1rem auto 0;box-shadow:0 6px 12px rgba(0,0,0,.18);}
.client-label{background:#2f6fe4;color:#fff;padding:.2rem .5rem;border-radius:9px;font-weight:700;font-size:.65rem;letter-spacing:.04em;box-shadow:0 6px 16px rgba(0,0,0,.16);transform:translateY(-6px);text-transform:uppercase;white-space:nowrap;}
.client-dot{width:12px;height:12px;background:#2f6fe4;border:3px solid #fff;border-radius:50%;margin:.1rem auto 0;box-shadow:0 6px 12px rgba(0,0,0,.16);}
.distance-label{text-align:center;font-weight:700;color:#2f6fe4;letter-spacing:.04em;font-size:.85rem;}
.eta-label{text-align:center;font-weight:600;color:#6b6b6b;font-size:.82rem;}
.status-label{text-align:center;font-weight:800;color:#f39c12;font-size:.82rem;}
@media(max-width:768px){.tracking-container{grid-template-columns:1fr;}.tracking-right{order:2}.tracking-left{order:1}}
</style>

{# ══ Leaflet JS — MUST load before our tracking script ════════════════════ #}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>

{# ══ TRACKING SCRIPT ═══════════════════════════════════════════════════════
   Key fixes vs original:
   ① Leaflet loaded BEFORE this script (was after — L was undefined)
   ② fetch uses ?_=timestamp to prevent browser/proxy caching
   ③ fetch sends Cache-Control: no-cache header
   ④ pollLocation declared ONCE, interval stored in outer-scope var → clearInterval works
   ⑤ stopAllTracking() reliably clears the interval and replaces map HTML
   ⑥ Driver marker setLatLng() called on EVERY poll response that has coords,
      not just when coords change — fixes "stuck marker" on localhost
   ⑦ map.invalidateSize() called after map is first created (fixes grey tiles)
   ⑧ Polling interval is 3 s (was 350 ms)
══════════════════════════════════════════════════════════════════════════ #}
<script>
(function () {
    'use strict';

    // ── Early exit: order already done, Twig rendered static message ───────
    var mapShell = document.getElementById('deliveryMap');
    if (!mapShell || !mapShell.dataset.locationUrl) { return; }

    // ── DOM refs ───────────────────────────────────────────────────────────
    var locationUrl  = mapShell.dataset.locationUrl;
    var mapLink      = document.getElementById('deliveryMapLink');
    var distLbl      = document.getElementById('distanceLabel');
    var etaLbl       = document.getElementById('etaLabel');
    var statusLbl    = document.getElementById('statusLabel');

    // ── State ──────────────────────────────────────────────────────────────
    var TERMINAL       = ['delivered', 'cancelled'];
    var mapInstance    = null;
    var driverMarker   = null;
    var clientMarker   = null;
    var routeLine      = null;
    var pollIntervalId = null;          // ← outer-scope so stopAll() can clear it
    var prevDriverLat  = null;
    var prevDriverLon  = null;
    var prevTime       = null;
    var speedSamples   = [];

    // ── Icons ──────────────────────────────────────────────────────────────
    var driverIcon = L.divIcon({
        className: 'driver-marker',
        html: '<div class="driver-label">Driver</div><div class="driver-dot"></div>',
        iconSize: [60, 40], iconAnchor: [30, 34]
    });
    var clientIcon = L.divIcon({
        className: 'client-marker',
        html: '<div class="client-label">You</div><div class="client-dot"></div>',
        iconSize: [46, 36], iconAnchor: [23, 32]
    });

    // ── Helpers ────────────────────────────────────────────────────────────
    function toNum(v) {
        var n = parseFloat(v);
        return isFinite(n) ? n : null;
    }

    function haversine(lat1, lon1, lat2, lon2) {
        var R    = 6371000;
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLon = (lon2 - lon1) * Math.PI / 180;
        var a    = Math.sin(dLat/2)*Math.sin(dLat/2)
                 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)
                 * Math.sin(dLon/2)*Math.sin(dLon/2);
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    }

    // ── stopAllTracking ────────────────────────────────────────────────────
    function stopAllTracking(status) {
        if (pollIntervalId !== null) { clearInterval(pollIntervalId); pollIntervalId = null; }
        var isOk = (status === 'delivered');
        mapShell.innerHTML = isOk
            ? '<div><strong style="color:#2E9E6A;font-size:1.05rem">✅ Your order has been delivered!</strong><div style="margin-top:.5rem;color:#666">Live tracking has ended.</div></div>'
            : '<div><strong style="color:#e74c3c;font-size:1.05rem">❌ Order Cancelled</strong><div style="margin-top:.5rem;color:#666">Live tracking has ended.</div></div>';
        mapShell.style.border = '1px solid ' + (isOk ? 'rgba(46,158,106,.3)' : 'rgba(231,76,60,.3)');
        mapShell.style.display = 'flex';
        if (distLbl) distLbl.style.display = 'none';
        if (etaLbl)  etaLbl.style.display  = 'none';
        if (statusLbl) {
            statusLbl.textContent = isOk ? '✅ Delivered' : '❌ Cancelled';
            statusLbl.style.color = isOk ? '#2E9E6A' : '#e74c3c';
            statusLbl.style.display = 'block';
        }
    }

    // ── ensureMap: create Leaflet instance the first time ──────────────────
    function ensureMap(lat, lon) {
        if (mapInstance) return;
        // Clear the placeholder text
        mapShell.innerHTML = '';
        mapShell.style.display = 'block';   // switch from flex (centering placeholder)
        mapShell.style.padding = '0';
        mapInstance = L.map(mapShell, { zoomControl: true }).setView([lat, lon], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(mapInstance);
        // ① Fix grey tiles on first render
        setTimeout(function () { mapInstance.invalidateSize(); }, 200);
    }

    // ── renderMap: place/move markers and update distance line ─────────────
    function renderMap(cLat, cLon, dLat, dLon) {
        if (cLat === null || cLon === null) return null;

        ensureMap(cLat, cLon);

        // Client marker
        if (!clientMarker) {
            clientMarker = L.marker([cLat, cLon], { icon: clientIcon }).addTo(mapInstance);
        } else {
            clientMarker.setLatLng([cLat, cLon]);
        }

        var meters = null;

        if (dLat !== null && dLon !== null) {
            // ② Always call setLatLng — even if coords are identical on localhost
            if (!driverMarker) {
                driverMarker = L.marker([dLat, dLon], { icon: driverIcon }).addTo(mapInstance);
            } else {
                driverMarker.setLatLng([dLat, dLon]);
            }

            var pts = [[cLat, cLon], [dLat, dLon]];
            if (!routeLine) {
                routeLine = L.polyline(pts, { color: '#2f6fe4', weight: 3, opacity: .95, dashArray: '6 8' }).addTo(mapInstance);
            } else {
                routeLine.setLatLngs(pts);
            }

            meters = haversine(cLat, cLon, dLat, dLon);
            var lineColor = meters < 500 ? '#2ecc71' : (meters < 2000 ? '#f39c12' : '#e74c3c');
            routeLine.setStyle({ color: lineColor });

            // Fit bounds to show both markers
            mapInstance.fitBounds(pts, { padding: [40, 40] });

            // Distance label
            if (distLbl) {
                distLbl.textContent = 'Distance: ' + (meters >= 1000
                    ? (meters/1000).toFixed(2)+' km away'
                    : Math.round(meters)+' m away');
                distLbl.style.display = 'block';
            }

            // Google Maps link
            if (mapLink) {
                mapLink.href = 'https://www.google.com/maps/dir/?api=1'
                    + '&origin='      + dLat + ',' + dLon
                    + '&destination=' + cLat + ',' + cLon
                    + '&travelmode=driving';
                mapLink.style.pointerEvents = 'auto';
                mapLink.style.opacity = '1';
            }
        } else {
            // No driver yet — show client location only
            if (routeLine) { mapInstance.removeLayer(routeLine); routeLine = null; }
            mapInstance.setView([cLat, cLon], 15);
            if (distLbl) distLbl.style.display = 'none';
            if (mapLink) {
                mapLink.href = 'https://www.google.com/maps/search/?api=1&query=' + cLat + ',' + cLon;
                mapLink.style.pointerEvents = 'auto';
                mapLink.style.opacity = '1';
            }
        }

        return meters;
    }

    // ── updateLabels: ETA + status text ───────────────────────────────────
    function updateLabels(meters) {
        if (meters === null) return;
        var avgSpeed = speedSamples.length
            ? speedSamples.reduce(function(a,b){return a+b;},0) / speedSamples.length
            : 6;                               // default 6 m/s (≈22 km/h scooter)
        if (avgSpeed < 0.5) avgSpeed = 6;
        var etaSec  = Math.max(0, Math.round(meters / avgSpeed));
        var etaTxt  = etaSec < 60 ? etaSec+'s' : (etaSec < 3600 ? Math.round(etaSec/60)+' min' : Math.round(etaSec/3600)+' h');

        if (etaLbl) { etaLbl.textContent = 'ETA: '+etaTxt; etaLbl.style.display='block'; }

        if (statusLbl) {
            var txt='On the way', color='#2f6fe4';
            if (meters < 50)  { txt='Arriving now'; color='#2ecc71'; }
            else if (meters < 500) { txt='Nearly there'; color='#f39c12'; }
            statusLbl.textContent=txt; statusLbl.style.color=color; statusLbl.style.display='block';
        }
    }

    // ── Initial render from Twig data-* attributes ─────────────────────────
    var initClientLat = toNum(mapShell.dataset.clientLat);
    var initClientLon = toNum(mapShell.dataset.clientLon);
    var initDriverLat = toNum(mapShell.dataset.driverLat);
    var initDriverLon = toNum(mapShell.dataset.driverLon);

    // We always use the Twig-provided client coords — they don't change
    var clientLat = initClientLat;
    var clientLon = initClientLon;

    if (clientLat !== null && clientLon !== null) {
        var m = renderMap(clientLat, clientLon, initDriverLat, initDriverLon);
        if (m !== null) updateLabels(m);
    }

    // ── pollLocation ───────────────────────────────────────────────────────
    // ③ Cache-bust with ?_=timestamp so browser never serves stale response
    // ④ Cache-Control header tells any intermediate proxy not to cache
    function pollLocation() {
        fetch(locationUrl + '?_=' + Date.now(), {
            credentials: 'same-origin',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Cache-Control':    'no-cache, no-store'
            }
        })
        .then(function (r) {
            if (!r.ok) { console.warn('[Tracking] Poll HTTP', r.status); return null; }
            return r.json();
        })
        .then(function (data) {
            if (!data) return;

            console.log('[Tracking] Poll:', data);

            // ⑤ Stop if terminal
            if (data.status && TERMINAL.indexOf(data.status.toLowerCase()) !== -1) {
                stopAllTracking(data.status.toLowerCase());
                return;
            }

            var dLat = toNum(data.driver_latitude);
            var dLon = toNum(data.driver_longitude);

            // Update client coords if server returns fresher ones
            if (toNum(data.client_latitude) !== null)  clientLat = toNum(data.client_latitude);
            if (toNum(data.client_longitude) !== null)  clientLon = toNum(data.client_longitude);

            // Speed estimation (for ETA)
            if (dLat !== null && dLon !== null && prevDriverLat !== null) {
                var now  = Date.now();
                var dt   = Math.max((now - prevTime) / 1000, 0.001);
                var dist = haversine(prevDriverLat, prevDriverLon, dLat, dLon);
                var spd  = dist / dt;
                if (isFinite(spd) && spd >= 0) {
                    speedSamples.push(spd);
                    if (speedSamples.length > 8) speedSamples.shift();
                }
                prevTime = now;
            } else if (dLat !== null) {
                prevTime = Date.now();
            }
            prevDriverLat = dLat;
            prevDriverLon = dLon;

            // ⑥ Always render — setLatLng even if coords haven't changed
            //    (fixes "stuck" appearance on localhost where GPS never changes)
            var meters = renderMap(clientLat, clientLon, dLat, dLon);
            if (meters !== null) updateLabels(meters);
        })
        .catch(function (err) {
            console.warn('[Tracking] Poll error:', err);
        });
    }

    // ── Start polling: immediate call + every 3 s ──────────────────────────
    // ⑦ 3 s is plenty — driver GPS pushes every 6 s anyway
    pollLocation();
    pollIntervalId = setInterval(pollLocation, 3000);

    // ── Rating star helpers ────────────────────────────────────────────────
    document.querySelectorAll('.rating-stars label').forEach(function (lbl) {
        lbl.addEventListener('click', function () {
            var el = document.getElementById(lbl.getAttribute('for'));
            if (el) el.checked = true;
        });
    });

    // ── Scroll active timeline step into view ─────────────────────────────
    var activeStep = document.querySelector('.timeline-item.active');
    if (activeStep) activeStep.scrollIntoView({ behavior: 'smooth', block: 'center' });

    // ── Re-validate map on tab focus / visibility restore ─────────────────
    function revalidate() {
        if (mapInstance) {
            try { mapInstance.invalidateSize(); } catch(e) {}
        }
    }
    document.addEventListener('visibilitychange', function () { if (!document.hidden) revalidate(); });
    window.addEventListener('focus', revalidate);

})();
</script>

{% endblock %}
