<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Your BIG 4 password reset code</title>
</head>
<body style="margin:0;padding:0;background:#f9f5ec;font-family:Arial,sans-serif;color:#2C1A0E;">
    <div style="max-width:620px;margin:0 auto;padding:32px 16px;">
        <div style="background:#fff;border:1px solid rgba(184,135,42,.18);border-radius:24px;overflow:hidden;box-shadow:0 24px 60px rgba(141,109,57,.12);">
            <div style="padding:28px 32px;background:linear-gradient(135deg,#fff3cd,#fff4de);border-bottom:1px solid rgba(184,135,42,.18);">
                <div style="font-size:22px;font-weight:700;letter-spacing:.12em;color:#B8872A;">BIG 4</div>
                <div style="font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#8C6340;margin-top:4px;">Coffee Lounge</div>
            </div>
            <div style="padding:32px;">
                <h1 style="margin:0 0 16px;font-size:26px;color:#5C3D1E;">Your password reset code</h1>
                <p style="margin:0 0 18px;line-height:1.7;">Your password reset code is:</p>
                <div style="margin:0 0 22px;padding:18px 24px;border-radius:18px;background:#FBF4E3;border:1px solid rgba(184,135,42,.24);font-size:32px;font-weight:800;letter-spacing:.18em;text-align:center;color:#B8872A;">
                    {{ code }}
                </div>
                <p style="margin:0 0 12px;line-height:1.7;">This code expires in 10 minutes.</p>
                <p style="margin:0;line-height:1.7;color:#7A5C3A;">If you did not request this, you can ignore this email.</p>
            </div>
        </div>
    </div>
</body>
</html>
