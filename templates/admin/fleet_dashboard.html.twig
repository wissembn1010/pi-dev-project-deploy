{% extends 'admin_base.html.twig' %}

{% block title %}Fleet Dashboard - Admin{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<style>
    .fleet-page {
        color: #171923;
    }

    .fleet-top {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 2rem;
        align-items: end;
        margin-bottom: 2rem;
    }

    .fleet-title h1 {
        margin: 0;
        color: #171923;
        font-family: 'Jost', sans-serif;
        font-size: 2rem;
        font-weight: 700;
    }

    .fleet-title p {
        margin: .35rem 0 0;
        color: #6f6a62;
        font-size: 1rem;
    }

    .fleet-stats {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .fleet-stat {
        width: 86px;
        min-height: 86px;
        background: #fff;
        border: 1px solid rgba(44, 26, 14, .08);
        border-radius: 14px;
        box-shadow: 0 10px 28px rgba(92, 61, 30, .10);
        display: grid;
        place-items: center;
        text-align: center;
        padding: .9rem .5rem;
    }

    .fleet-stat strong {
        display: block;
        font-size: 1.55rem;
        line-height: 1;
        font-weight: 800;
    }

    .fleet-stat span {
        display: block;
        margin-top: .55rem;
        color: #9a958f;
        font-size: .68rem;
        letter-spacing: .13em;
        text-transform: uppercase;
    }

    .fleet-stat.online strong { color: #00a85a; }
    .fleet-stat.active strong { color: #146bd7; }
    .fleet-stat.alerts strong { color: #d70000; }

    .fleet-analytics-btn,
    .ai-assign-btn {
        border: 1px solid rgba(184, 135, 42, .42);
        background: linear-gradient(180deg, #d1a34a 0%, #b8872a 100%);
        color: #fff;
        border-radius: 10px;
        padding: .72rem 1.2rem;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 8px 0 #9b6e1d;
        transition: transform .18s ease, box-shadow .18s ease;
        white-space: nowrap;
    }

    .fleet-analytics-btn {
        background: rgba(255, 250, 240, .88);
        color: #b8872a;
        box-shadow: none;
    }

    .fleet-analytics-btn:hover,
    .ai-assign-btn:hover {
        transform: translateY(-1px);
        color: #fff;
    }

    .fleet-analytics-btn:hover {
        color: #b8872a;
        background: #fff8e8;
    }

    .fleet-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 2rem;
        align-items: start;
    }

    .fleet-map-card {
        position: relative;
        overflow: hidden;
        border-radius: 14px;
        background: #252525;
        box-shadow: 0 18px 45px rgba(92, 61, 30, .18);
        min-height: 620px;
    }

    #fleetMap {
        min-height: 620px;
        height: 68vh;
        width: 100%;
        background: #262626;
    }

    .map-empty {
        position: absolute;
        left: 1rem;
        bottom: 1rem;
        z-index: 500;
        background: rgba(23, 25, 35, .88);
        color: #f8efe0;
        border: 1px solid rgba(255, 255, 255, .12);
        border-radius: 10px;
        padding: .85rem 1rem;
        max-width: 360px;
        font-size: .85rem;
        box-shadow: 0 10px 28px rgba(0, 0, 0, .25);
    }

    .fleet-sidebar {
        display: grid;
        gap: 1rem;
    }

    .pending-card,
    .alerts-card {
        background: rgba(255, 255, 255, .76);
        border: 1px solid rgba(184, 135, 42, .16);
        border-radius: 16px;
        box-shadow: 0 18px 45px rgba(92, 61, 30, .10);
        overflow: hidden;
    }

    .side-card-head {
        padding: 1.25rem 1.35rem;
        border-bottom: 1px solid rgba(184, 135, 42, .12);
        color: #26303d;
        font-weight: 800;
        font-size: 1.05rem;
    }

    .pending-list,
    .alert-list {
        display: grid;
        gap: .35rem;
        padding: 1rem;
        max-height: 520px;
        overflow: auto;
    }

    .pending-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: .75rem;
        align-items: center;
        padding: .7rem .5rem;
        border-radius: 10px;
    }

    .pending-row:hover {
        background: rgba(184, 135, 42, .07);
    }

    .pending-main {
        min-width: 0;
        color: #969aa3;
        font-size: .9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pending-main strong {
        color: #26303d;
        margin-right: .35rem;
    }

    .ai-assign-btn {
        border: none;
        box-shadow: none;
        padding: .58rem .85rem;
        font-size: .84rem;
        cursor: pointer;
    }

    .empty-state {
        padding: 1.2rem;
        color: #8c8175;
        text-align: center;
        font-size: .9rem;
    }

    .alert-item {
        border: 1px solid rgba(217, 64, 64, .18);
        background: rgba(217, 64, 64, .08);
        color: #8c1d1d;
        border-radius: 10px;
        padding: .85rem 1rem;
        font-size: .86rem;
        line-height: 1.45;
    }

    .fleet-flash {
        margin-bottom: 1rem;
    }

    .leaflet-popup-content-wrapper,
    .leaflet-popup-tip {
        background: #1f2328;
        color: #f8efe0;
        box-shadow: 0 14px 35px rgba(0, 0, 0, .35);
    }

    .driver-popup strong {
        color: #e7bd63;
    }

    .driver-popup span {
        display: block;
        margin-top: .25rem;
    }

    @media (max-width: 1100px) {
        .fleet-top,
        .fleet-shell {
            grid-template-columns: 1fr;
        }

        .fleet-stats {
            justify-content: flex-start;
        }

        .fleet-map-card,
        #fleetMap {
            min-height: 480px;
            height: 58vh;
        }
    }

    @media (max-width: 640px) {
        .fleet-stat {
            width: calc(33.333% - .7rem);
        }

        .fleet-analytics-btn {
            width: 100%;
            text-align: center;
        }

        .pending-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="fleet-page">
    <div class="fleet-top">
        <div class="fleet-title">
            <h1>🚚 Fleet Dashboard</h1>
            <p>Live driver tracking · AI assignments · Real-time alerts</p>
        </div>
        <div class="fleet-stats">
            <div class="fleet-stat online">
                <div><strong>{{ onlineCount }}</strong><span>Online</span></div>
            </div>
            <div class="fleet-stat active">
                <div><strong>{{ activeCount }}</strong><span>Active</span></div>
            </div>
            <div class="fleet-stat alerts">
                <div><strong>{{ alertCount }}</strong><span>Alerts</span></div>
            </div>
            <a href="{{ path('app_admin_analytics') }}" class="fleet-analytics-btn">📊 Analytics</a>
        </div>
    </div>

    <div class="fleet-flash">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {% if alerts|length > 0 %}
        <div class="alerts-card" style="margin-bottom: 1.4rem;">
            <div class="side-card-head">⚠️ Real-time Alerts</div>
            <div class="alert-list">
                {% for alert in alerts %}
                    <div class="alert-item">{{ alert }}</div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="fleet-shell">
        <div class="fleet-map-card">
            <div id="fleetMap"></div>
            {% if not hasMarkers %}
                <div class="map-empty">No driver locations yet. Add latitude, longitude, and a recent last seen time for a delivery man to show live markers.</div>
            {% endif %}
        </div>

        <aside class="fleet-sidebar">
            <div class="pending-card">
                <div class="side-card-head">📦 Pending Assignment</div>
                {% if pendingDeliveries|length > 0 %}
                    <div class="pending-list">
                        {% for delivery in pendingDeliveries %}
                            {% set label = delivery.deliveryAddress ?: delivery.recipientName ?: 'No address' %}
                            <div class="pending-row">
                                <div class="pending-main" title="{{ label }}">
                                    <strong>#{{ delivery.deliveryId }}</strong>{{ label|length > 18 ? label|slice(0, 18) ~ '...' : label }}
                                </div>
                                <form method="post" action="{{ path('admin_fleet_dashboard_ai_assign', {id: delivery.deliveryId}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('fleet_ai_assign' ~ delivery.deliveryId) }}">
                                    <button type="submit" class="ai-assign-btn">🤖 AI Assign</button>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-state">No deliveries are waiting for assignment.</div>
                {% endif %}
            </div>
        </aside>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const fleetMarkers = {{ markers|json_encode|raw }};
    const map = L.map('fleetMap', {
        zoomControl: true,
        scrollWheelZoom: true
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
        maxZoom: 19
    }).addTo(map);

    const bounds = [];
    const escapeHtml = (value) => String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    fleetMarkers.forEach((driver) => {
        const color = driver.online ? '#e7bd63' : '#8e8e8e';
        const marker = L.circleMarker([driver.lat, driver.lng], {
            radius: 10,
            color: '#fff4cf',
            weight: 2,
            fillColor: color,
            fillOpacity: .9
        }).addTo(map);

        marker.bindPopup(`
            <div class="driver-popup">
                <strong>${escapeHtml(driver.name)}</strong>
                <span>Status: ${driver.online ? 'online' : 'offline'}</span>
                <span>Active delivery: ${escapeHtml(driver.activeDelivery)}</span>
                <span>Last seen: ${escapeHtml(driver.lastSeen)}</span>
            </div>
        `);
        bounds.push([driver.lat, driver.lng]);
    });

    if (bounds.length > 0) {
        map.fitBounds(bounds, { padding: [45, 45], maxZoom: 13 });
    } else {
        map.setView([36.8065, 10.1815], 11);
    }
</script>
{% endblock %}
