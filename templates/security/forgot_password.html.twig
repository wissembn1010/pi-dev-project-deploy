{% extends 'base.html.twig' %}

{% block title %}Forgot Password - BIG 4{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-panel">
            <div class="auth-intro">
                <span class="auth-tag">BIG 4 Coffee Lounge</span>
                <h1>Reset your password</h1>
                <p>Enter your account email and we’ll send a six-digit verification code if the account exists.</p>
            </div>
            <div class="auth-side">
                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}

                <form method="post" action="{{ path('app_forgot_password') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}">
                    <div class="form-row">
                        <label for="forgot_email">Email</label>
                        <input id="forgot_email" type="email" name="email" autocomplete="email" required>
                    </div>
                    <button type="submit" class="btn btn-primary">Send Reset Code</button>
                </form>

                <p class="auth-footer">
                    Remembered it? <a href="{{ path('app_login') }}">Back to login</a>
                </p>
            </div>
        </div>
    </div>
</div>

{% include 'security/_auth_styles.html.twig' %}
{% endblock %}
